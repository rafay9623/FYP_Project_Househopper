# Frontend API Variables
VITE_API_URL=http://localhost:3001

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin Configuration (for testing/bypass)
VITE_ADMIN_EMAIL=admin@househoppers.com
VITE_ADMIN_PASSWORD=admin_password

# Google Maps (Optional for HeatMap)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
