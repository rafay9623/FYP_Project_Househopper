# ============================================
# Server Configuration
# ============================================
PORT=3001
FRONTEND_URL=http://localhost:5173

# ============================================
# Clerk Authentication (Backend)
# ============================================
# Get your Clerk Secret Key from: https://dashboard.clerk.com/
# Go to API Keys section and copy the Secret Key
CLERK_SECRET_KEY=your_secret_key

# ============================================
# Firebase Admin SDK Configuration (Backend)
# ============================================
# For backend server, you need Admin SDK credentials (different from web app config)

# Option 1: Use service account JSON file (recommended)
# Download firebase-service-account.json from Firebase Console:
# https://console.firebase.google.com/project/your-project-id/settings/serviceaccounts/adminsdk
# Place it in the server/ directory
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Use individual Admin SDK credentials (alternative)
# Extract these values from your service account JSON file:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----"

